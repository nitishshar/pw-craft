# --- Application under test ---
PWCRAFT_BASE_URL=http://localhost:4200

# --- Browser session (PwCraftSession / loadPwCraftConfigFromEnv) ---
PWCRAFT_BROWSER=chromium
PWCRAFT_HEADLESS=true
PWCRAFT_TIMEOUT=60000

# --- Playwright Test: screenshots, video, trace (playwright.config.ts use.*) ---
# PWCRAFT_SCREENSHOT_CAPTURE: on-failure | always | never (mapped to Playwright screenshot mode)
PWCRAFT_SCREENSHOT_CAPTURE=on-failure
# Video: set PWCRAFT_VIDEO_RECORD_MODE for full control (on | off | retain-on-failure), or PWCRAFT_VIDEO_RECORD=true for always on
PWCRAFT_VIDEO_RECORD=true
PWCRAFT_VIDEO_RECORD_MODE=on
# Trace: on-first-retry | on | off | retain-on-failure
PWCRAFT_TRACE_CAPTURE=on

# --- Gherkin step attachments (PwCraftConfig.gherkin.attachments) ---
PWCRAFT_STEP_SCREENSHOTS=true
PWCRAFT_STEP_SCREENSHOTS_FULL_PAGE=false
# Attach video/trace zips via testInfo (never | always | on-failure); trace zip needs PWCRAFT_TRACE_CAPTURE not off
PWCRAFT_ATTACH_VIDEO=never
PWCRAFT_ATTACH_TRACE_ZIP=on-failure

# --- Playwright HTML report ---
PLAYWRIGHT_HTML_OUTPUT_DIR=playwright-report
PLAYWRIGHT_HTML_OPEN=on-failure
PLAYWRIGHT_HTML_TITLE=pw-craft - Gherkin (Playwright)

# --- Monocart HTML report ---
MONOCART_REPORT_FILE=monocart-report/index.html

# --- CI (set by CI providers; leave unset locally) ---
# CI=
