# Base URL for the application under test (used when baseUrl is not set in config)
PWCRAFT_BASE_URL=http://localhost:4200

# Browser: chromium | firefox | webkit
PWCRAFT_BROWSER=chromium

# Run browser headless (true/false)
PWCRAFT_HEADLESS=true

# Default timeout in milliseconds for actions and navigations
PWCRAFT_TIMEOUT=30000

# Screenshot capture mode: on-failure | always | never
PWCRAFT_SCREENSHOT_CAPTURE=on-failure

# Video recording: true | false
PWCRAFT_VIDEO_RECORD=false

# Playwright trace capture: on-first-retry | on | off | retain-on-failure
PWCRAFT_TRACE_CAPTURE=off

# Capture a screenshot after every Cucumber step (true/false)
PWCRAFT_STEP_SCREENSHOTS=false
